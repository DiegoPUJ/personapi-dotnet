@model personapi_dotnet.Models.Entities.Telefono

@{
    ViewData["Title"] = "Eliminar Teléfono";
}

<h1>Eliminar Teléfono</h1>

<h4>¿Está seguro de eliminar este teléfono?</h4>

<table class="table table-bordered">
    <tr>
        <th>Número</th>
        <td>@Model.Num</td>
    </tr>
    <tr>
        <th>Operador</th>
        <td>@Model.Oper</td>
    </tr>
    <tr>
        <th>Dueño</th>
        <td>@Model.Duenio</td>
    </tr>
    <tr>
        <th>Persona</th>
        <td>
            @if (Model.DuenioNavigation != null)
            {
                @($"{Model.DuenioNavigation.Nombre} {Model.DuenioNavigation.Apellido}")
            }
        </td>
    </tr>
</table>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Num" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>