@model personapi_dotnet.Models.Entities.Profesion

@{
    ViewData["Title"] = "Editar Profesión";
}

<h1>Editar Profesión</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="Id" class="control-label">ID</label>
        <input asp-for="Id" class="form-control" readonly />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Nom" class="control-label">Nombre</label>
        <input asp-for="Nom" class="form-control" />
        <span asp-validation-for="Nom" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Des" class="control-label">Descripción</label>
        <textarea asp-for="Des" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Des" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Actualizar</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>