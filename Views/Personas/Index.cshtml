@model IEnumerable<personapi_dotnet.Models.Entities.Persona>

@{
    ViewData["Title"] = "Personas";
}

<h1>Listado de Personas</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear nueva persona</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Cédula</th>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Género</th>
            <th>Edad</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Cc</td>
                <td>@item.Nombre</td>
                <td>@item.Apellido</td>
                <td>@item.Genero</td>
                <td>@item.Edad</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Cc" class="btn btn-info btn-sm">Detalles</a>
                    <a asp-action="Edit" asp-route-id="@item.Cc" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Cc" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>